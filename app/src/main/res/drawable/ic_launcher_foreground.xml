<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- 信号监测仪图标 - 信号柱状图设计 -->
    <!-- 4根信号柱，逐渐增高，代表信号强度 -->
    
    <!-- 第1根柱 (最矮 - 1格信号) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M28,78 L40,78 L40,90 L28,90 Z" />
    
    <!-- 第2根柱 (较矮 - 2格信号) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M44,66 L56,66 L56,90 L44,90 Z" />
    
    <!-- 第3根柱 (较高 - 3格信号) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M60,54 L72,54 L72,90 L60,90 Z" />
    
    <!-- 第4根柱 (最高 - 4格信号) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M76,42 L88,42 L88,90 L76,90 Z" />
    
    <!-- 底部基线 -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M24,90 L92,90"
        android:strokeWidth="2"
        android:strokeColor="#FFFFFF" />
    
    <!-- 顶部小圆点 - 代表"监测" -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M53,30 A3,3 0 1,1 54,30 A3,3 0 1,1 53,30 Z" />
</vector>
