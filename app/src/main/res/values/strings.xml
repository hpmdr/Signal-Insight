    <!-- PCI 科普（新增强化版） -->
    <string name="metric_pci_label">PCI</string>
    <string name="metric_pci_full">物理小区标识 (Physical Cell ID)</string>
    <string name="metric_pci_desc">用来区分不同基站的"身份证号"。</string>
    <string name="metric_pci_impact">当 PCI 发生变化时，说明你的手机完成了基站切换。</string>
    <string name="metric_pci_tip">如果 PCI 频繁跳变，说明你处于两个基站交界处。</string>
    <string name="pci_explain_title">什么是 PCI？</string>
    <string name="pci_explain_basic">PCI（物理小区标识）是网络分配给每个小区扇区的唯一编号，用于帮助手机区分邻近的基站。4G LTE 的 PCI 范围为 0~503，5G NR 的 PCI 范围为 0~1007。</string>
    <string name="pci_handover_title">基站切换原理</string>
    <string name="pci_handover_normal">正常切换：PCI 变化代表切换到新基站</string>
    <string name="pci_handover_normal_desc">当你从一个小区的覆盖区域移动到另一个小区时，手机会自动切换到信号更强的基站，PCI 随之变化。</string>
    <string name="pci_handover_frequent">频繁切换：PCI 不稳定</string>
    <string name="pci_handover_frequent_desc">如果 PCI 在短时间内多次变化（每分钟数次），说明你处于基站交界处或信号不稳定。</string>
    <string name="pci_mod3_title">PCI Mod 3 干扰</string>
    <string name="pci_mod3_desc">在 4G LTE 网络中，相邻小区的 PCI Mod 3 值不能相同，否则会产生信号干扰。这就是为什么运营商需要精心规划 PCI 分配。</string>
    <string name="pci_assessment_title">当前 PCI 评估</string>
    <string name="pci_assessment_stable">当前 PCI 稳定。你的连接保持在同一基站。</string>
    <string name="pci_assessment_changed">PCI 已变化。你的手机已切换到新的基站。</string>

    <!-- EARFCN 科普（新增强化版） -->
    <string name="metric_earfcn_label">EARFCN</string>
    <string name="metric_earfcn_full">中心频点</string>
    <string name="metric_earfcn_desc">代表基站工作的精确频率位置。通过此数值计算基站确切的下行频率。</string>
    <string name="metric_earfcn_impact">不同的运营商拥有不同的频点范围。</string>
    <string name="metric_earfcn_tip">通过 EARFCN 可以换算出基站的确切工作频率（MHz）。</string>
    <string name="earfcn_explain_title">什么是 EARFCN？</string>
    <string name="earfcn_explain_basic">EARFCN（绝对无线频率信道编号）是代表基站中心频率的编号。运营商使用它来标识基站广播的特定信道。</string>
    <string name="earfcn_formula_title">频率换算</string>
    <string name="earfcn_formula_4g">4G LTE：Fdl = Fdl_low + 0.1 × (EARFCN - Ndl)</string>
    <string name="earfcn_formula_4g_note">每个 EARFCN 对应一个具体的下行频率（MHz）。</string>
    <string name="earfcn_operator_title">运营商频点范围</string>
    <string name="earfcn_operator_mobile">中国移动：B3(1800MHz), B8(900MHz), B39(1900MHz), n41(2.6GHz), n79(4.9GHz)</string>
    <string name="earfcn_operator_unicom">中国联通：B1(2100MHz), B3(1800MHz), n78(3.5GHz)</string>
    <string name="earfcn_operator_telecom">中国电信：B1(2100MHz), B3(1800MHz), B5(850MHz), n78(3.5GHz)</string>
    <string name="earfcn_operator_broadcast">中国广电：n28(700MHz), n79(4.9GHz)</string>
    <string name="earfcn_assessment_title">当前 EARFCN 评估</string>
    <string name="earfcn_assessment_text">你的手机连接到了特定频率信道。同一频段内不同信道的性能特性相近。</string>

    <!-- TAC 科普（新增强化版） -->
    <string name="metric_tac_label">TAC</string>
    <string name="metric_tac_full">跟踪区域代码 (Tracking Area Code)</string>
    <string name="metric_tac_desc">运营商将基站划分成不同的"片区"进行管理。</string>
    <string name="metric_tac_impact">跨区域移动时 TAC 会更新。</string>
    <string name="metric_tac_tip">TAC 的变化频率低于 PCI，通常在跨区域出行时才会更新。</string>
    <string name="tac_explain_title">什么是 TAC？</string>
    <string name="tac_explain_basic">TAC（跟踪区域代码）是为特定地理区域的一组基站分配的编号。运营商使用 TAC 来管理寻呼——当有人拨打你的电话时，网络只会在你当前 TAC 内的基站进行寻呼，而不是全网广播。</string>
    <string name="tac_update_title">TAC 何时更新</string>
    <string name="tac_update_move">移动到新城区或市中心</string>
    <string name="tac_update_highway">驾车行驶在城市之间的高速公路上</string>
    <string name="tac_update_subway">地铁或火车经过不同区域</string>
    <string name="tac_update_airport">乘坐飞机到达新城市</string>
    <string name="tac_purpose_title">TAC 的作用</string>
    <string name="tac_purpose_paging">高效寻呼：只在当前区域内的基站寻呼</string>
    <string name="tac_purpose_location">位置跟踪：帮助网络知道你所在的区域</string>
    <string name="tac_purpose_balance">负载均衡：避免网络资源浪费</string>
    <string name="tac_assessment_title">当前 TAC 评估</string>
    <string name="tac_assessment_stable">当前 TAC 稳定。你所在的跟踪区域没有变化。</string>
    <string name="tac_assessment_changed">TAC 已更新。你已进入新的跟踪区域。</string>

    <string name="metric_not_available">当前网络不支持此指标</string>
    <string name="metric_no_data">无数据</string>

