    <!-- RSRP 科普（新增强化版） -->
    <string name="metric_rsrp_label">RSRP</string>
    <string name="metric_rsrp_full">参考信号接收功率 (Reference Signal Received Power)</string>
    <string name="metric_rsrp_desc">这是衡量 4G/5G 信号强度的最直接指标。它表示手机接收到基站信号的功率大小。</string>
    <string name="metric_rsrp_impact">数值越接近 0，信号越强。如果数值太低，你会感觉到网页打不开，通话断断续续。</string>
    <string name="metric_rsrp_tip">RSRP 是衡量信号覆盖的最核心指标，信号强度的测量单位是 dBm。</string>
    <string name="rsrp_explain_title">什么是 RSRP？</string>
    <string name="rsrp_explain_basic">RSRP（参考信号接收功率）是手机测量基站发出的参考信号的功率值，是衡量 4G/5G 信号强度的最核心指标。它的单位是 dBm（分贝毫瓦），数值越接近 0 表示信号越强。</string>
    <string name="rsrp_range_title">RSRP 信号强度分级</string>
    <string name="rsrp_range_excellent">极佳（> -85dBm）</string>
    <string name="rsrp_range_excellent_desc">信号极强，速度和稳定性最佳，接近基站</string>
    <string name="rsrp_range_good">良好（-85 ~ -95dBm）</string>
    <string name="rsrp_range_good_desc">信号良好，日常使用体验流畅</string>
    <string name="rsrp_range_fair">一般（-95 ~ -105dBm）</string>
    <string name="rsrp_range_fair_desc">信号一般，网速可能下降但基本可用</string>
    <string name="rsrp_range_poor">较差（-105 ~ -115dBm）</string>
    <string name="rsrp_range_poor_desc">信号较弱，可能遇到网页加载慢、通话质量下降</string>
    <string name="rsrp_range_weak">极弱（&lt; -115dBm）</string>
    <string name="rsrp_range_weak_desc">信号极弱，可能掉线，建议靠近窗户或室外</string>
    <string name="rsrp_factor_title">影响信号强度的因素</string>
    <string name="rsrp_factor_distance">与基站的距离：越远信号越弱</string>
    <string name="rsrp_factor_obstacle">建筑物遮挡：钢筋混凝土墙体衰减严重</string>
    <string name="rsrp_factor_weather">天气影响：大雨、大雾有轻微衰减</string>
    <string name="rsrp_factor_load">用户密度：基站负载高时信号会波动</string>
    <string name="rsrp_assessment_title">当前信号评估</string>
    <string name="rsrp_assessment_excellent">当前信号极佳！你距离基站很近，5G 体验达到最佳状态。</string>
    <string name="rsrp_assessment_good">信号良好，日常使用体验流畅。如果感觉不理想，可以尝试调整位置。</string>
    <string name="rsrp_assessment_fair">信号一般，网速可能受影响。建议靠近窗户或到室外空旷处。</string>
    <string name="rsrp_assessment_poor">信号较弱。建议移动到窗户附近或室外，避开建筑物遮挡。</string>
    <string name="rsrp_assessment_weak">信号极弱。请在室内靠近窗户，或到户外无遮挡区域。</string>
    <!-- 保留旧版 range 名称供 metricsDatabase 引用 -->
    <string name="range_rsrp_weak">极弱</string>
    <string name="range_rsrp_fair">一般</string>
    <string name="range_rsrp_excellent">极佳</string>
