    <!-- RSRP 科普（新增强化版） -->
    <string name="metric_rsrp_label">RSRP</string>
    <string name="metric_rsrp_full">参考信号接收功率 (Reference Signal Received Power)</string>
    <string name="metric_rsrp_desc">这是衡量 4G/5G 信号强度的最直接指标。它表示手机接收到基站信号的功率大小。</string>
    <string name="metric_rsrp_impact">数值越接近 0，信号越强。如果数值太低，你会感觉到网页打不开，通话断断续续。</string>
    <string name="metric_rsrp_tip">RSRP 是衡量信号覆盖的最核心指标，信号强度的测量单位是 dBm。</string>
    <string name="rsrp_explain_title">什么是 RSRP？</string>
    <string name="rsrp_explain_basic">RSRP（参考信号接收功率）是手机测量基站发出的参考信号的功率值，是衡量 4G/5G 信号覆盖强度最核心的指标。单位是 dBm（分贝毫瓦），数值越接近 0 表示信号越强。5G NR 使用 SSB-RSRP，4G LTE 使用 CRS-RSRP，两者的判定标准相近。</string>
    <string name="rsrp_range_title">RSRP 信号强度分级 (国际标准)</string>
    <string name="rsrp_range_excellent">极佳（> -80dBm）</string>
    <string name="rsrp_range_excellent_desc">信号极强，峰值吞吐量，VoLTE 高清，切换流畅</string>
    <string name="rsrp_range_good">良好（-80 ~ -90dBm）</string>
    <string name="rsrp_range_good_desc">信号良好，高速数据传输稳定，日常体验流畅</string>
    <string name="rsrp_range_fair">一般（-90 ~ -100dBm）</string>
    <string name="rsrp_range_fair_desc">信号中等，吞吐量开始下降，室内可能有衰减</string>
    <string name="rsrp_range_poor">较差（-100 ~ -110dBm）</string>
    <string name="rsrp_range_poor_desc">信号较弱，吞吐量明显下降，延迟增加，可能掉线</string>
    <string name="rsrp_range_weak">极弱（&lt; -110dBm）</string>
    <string name="rsrp_range_weak_desc">信号极弱，仅维持最低连接，可能无服务</string>
    <string name="rsrp_factor_title">影响信号强度的因素</string>
    <string name="rsrp_factor_distance">与基站的距离：越远信号越弱</string>
    <string name="rsrp_factor_obstacle">建筑物遮挡：钢筋混凝土墙体衰减严重</string>
    <string name="rsrp_factor_weather">天气影响：大雨、大雾有轻微衰减</string>
    <string name="rsrp_factor_load">用户密度：基站负载高时信号会波动</string>
    <string name="rsrp_assessment_title">当前信号评估</string>
    <string name="rsrp_assessment_excellent">当前信号极佳！你处于基站近点，5G 可达峰值速率，时延最低。</string>
    <string name="rsrp_assessment_good">信号良好，日常使用体验流畅。如果感觉不理想，可尝试调整位置。</string>
    <string name="rsrp_assessment_fair">信号中等，网速可能下降。建议靠近窗户或到室外空旷处。</string>
    <string name="rsrp_assessment_poor">信号较弱。建议移动到窗户附近或室外，避开建筑物遮挡。</string>
    <string name="rsrp_assessment_weak">信号极弱，可能处于服务边缘或盲区。</string>
    <!-- 保留旧版 range 名称供 metricsDatabase 引用 -->
    <string name="range_rsrp_weak">极弱</string>
    <string name="range_rsrp_fair">一般</string>
    <string name="range_rsrp_excellent">极佳</string>
