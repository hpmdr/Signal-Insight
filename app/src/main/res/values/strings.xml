    <string name="range_rsrq_medium">中</string>
    <string name="range_rsrq_good">优</string>

    <!-- RSRQ 科普（新增强化版） -->
    <string name="metric_rsrq_label">RSRQ</string>
    <string name="metric_rsrq_full">参考信号接收质量 (Reference Signal Received Quality)</string>
    <string name="metric_rsrq_desc">反映信号的"纯净度"。即使信号很强，如果干扰太多，质量也会很差。</string>
    <string name="metric_rsrq_impact">数值越低，说明环境干扰越大。这通常发生在人群密集的车站或商场。</string>
    <string name="metric_rsrq_tip">RSRQ 与 RSRP 结合使用才能全面评估信号状况。</string>
    <string name="rsrq_explain_title">什么是 RSRQ？</string>
    <string name="rsrq_explain_basic">RSRQ（参考信号接收质量）衡量的是信号的"纯净度"。即使 RSRP 显示信号很强，但如果环境中有很多干扰，RSRQ 会降低，实际体验仍然不佳。RSRQ 单位是 dB。</string>
    <string name="rsrq_range_title">RSRQ 质量分级</string>
    <string name="rsrq_range_good">优（> -10dB）</string>
    <string name="rsrq_range_good_desc">信号纯净，干扰少，体验极佳</string>
    <string name="rsrq_range_fair">中（-15 ~ -10dB）</string>
    <string name="rsrq_range_fair_desc">有一定干扰，但整体可用</string>
    <string name="rsrq_range_poor">差（&lt; -15dB）</string>
    <string name="rsrq_range_poor_desc">干扰较大，网速不稳定，可能出现在人群密集处</string>
    <string name="rsrq_joint_title">RSRP 与 RSRQ 联合判断</string>
    <string name="rsrq_joint_good_both">RSRP 强 + RSRQ 优 = 信号质量极佳！</string>
    <string name="rsrq_joint_good_both_desc">信号强度和纯净度都很好，这是最理想的网络状态。</string>
    <string name="rsrq_joint_strong_noise">RSRP 强 + RSRQ 差 = 干扰大</string>
    <string name="rsrq_joint_strong_noise_desc">虽然信号强度够，但环境干扰大。多发生在人群密集的车站、商场等地方。</string>
    <string name="rsrq_joint_weak_both">RSRP 弱 + RSRQ 差 = 信号差</string>
    <string name="rsrq_joint_weak_both_desc">信号强度和纯净度都差，建议移动到室外或靠近窗户处。</string>
    <string name="rsrq_assessment_title">当前信号质量评估</string>
    <string name="rsrq_assessment_good">信号纯净度高，干扰少，体验很好。</string>
    <string name="rsrq_assessment_fair">存在一定干扰，但如果 RSRP 信号强，体验仍然可以接受。</string>
    <string name="rsrq_assessment_poor">干扰较大。建议远离人群密集区域或大型电子设备。</string>

    <!-- SINR 科普（新增强化版） -->
    <string name="metric_sinr_label">SINR</string>
    <string name="metric_sinr_full">信噪比 (Signal to Interference plus Noise Ratio)</string>
    <string name="metric_sinr_desc">有用信号与噪声的比值。就像在嘈杂的房间里听人说话，比值越高听得越清楚。</string>
    <string name="metric_sinr_impact">这是决定你下载速度快慢的最核心指标。SINR 越高，5G 测速跑分就越高。</string>
    <string name="metric_sinr_tip">SINR 是影响实际网速的关键指标，比 RSRP 更能反映真实体验。</string>
    <string name="sinr_explain_title">什么是 SINR？</string>
    <string name="sinr_explain_basic">SINR（信噪比）是有用信号与干扰加噪声的比值。可以想象在嘈杂的房间里听人说话——信号是说话声，噪声是周围的嘈杂声。SINR 越高，你听得越清楚，网速就越快。单位是 dB。</string>
    <string name="sinr_range_title">SINR 与下载速度对应表</string>
    <string name="sinr_range_excellent">极速（> 20dB）</string>
    <string name="sinr_range_excellent_speed">5G 测速可达 800Mbps+，4G 可达 100Mbps+</string>
    <string name="sinr_range_good">流畅（10 ~ 20dB）</string>
    <string name="sinr_range_good_speed">5G 测速 300-800Mbps，日常使用非常流畅</string>
    <string name="sinr_range_fair">一般（5 ~ 10dB）</string>
    <string name="sinr_range_fair_speed">5G 测速 100-300Mbps，视频浏览正常</string>
    <string name="sinr_range_poor">较差（0 ~ 5dB）</string>
    <string name="sinr_range_poor_speed">网速较慢，网页加载可能有延迟</string>
    <string name="sinr_range_weak">卡顿（&lt; 0dB）</string>
    <string name="sinr_range_weak_speed">信噪比不足，可能掉线或无法连接</string>
    <string name="sinr_factor_title">影响 SINR 的因素</string>
    <string name="sinr_factor_location">距离基站越近，信号越强，SINR 越高</string>
    <string name="sinr_factor_crowd">人群密集导致干扰增加，SINR 下降</string>
    <string name="sinr_factor_handover">基站交界处切换频繁，SINR 可能波动</string>
    <string name="sinr_assessment_title">当前 SINR 评估</string>
    <string name="sinr_assessment_excellent">下载速度极快！这个 SINR 值下 5G 测速可达 800Mbps 以上。</string>
    <string name="sinr_assessment_good">下载流畅，日常使用无压力。靠近基站网速会更好。</string>
    <string name="sinr_assessment_fair">网速一般，看视频没问题但下载大文件可能较慢。</string>
    <string name="sinr_assessment_poor">网速较慢，建议走到开阔处改善信号环境。</string>
    <string name="sinr_assessment_weak">信噪比过低，建议移动到信号更好的位置。</string>
    <!-- 保留旧版 range 名称供 metricsDatabase 引用 -->
    <string name="range_sinr_poor">卡顿</string>
    <string name="range_sinr_fair">流畅</string>
    <string name="range_sinr_good">极速</string>

    <!-- RSSI 科普（新增强化版） -->
    <string name="metric_rssi_label">RSSI</string>
    <string name="metric_rssi_full">接收信号强度指示</string>
    <string name="metric_rssi_desc">手机接收到的总功率，包括有用信号、干扰和背景噪声。</string>
    <string name="metric_rssi_impact">在 4G/5G 系统中，其参考意义通常弱于 RSRP。</string>
    <string name="metric_rssi_tip">RSSI 测的是所有信号的总和，RSRP 只测有用信号。</string>
    <string name="rssi_explain_title">什么是 RSSI？</string>
    <string name="rssi_explain_basic">RSSI（接收信号强度指示）是手机接收到的总功率，包括有用信号、干扰和背景噪声。它是一个比 RSRP 更宽泛的指标。单位是 dBm。</string>
    <string name="rssi_vs_rsrp_title">RSSI 与 RSRP 的区别</string>
    <string name="rssi_vs_rsrp_large">RSSI >> RSRP = 干扰大</string>
    <string name="rssi_vs_rsrp_large_desc">如果 RSSI 远高于 RSRP，说明环境中存在大量干扰。</string>
    <string name="rssi_vs_rsrp_small">RSSI ≈ RSRP = 信号纯净</string>
    <string name="rssi_vs_rsrp_small_desc">如果 RSSI 接近 RSRP，说明信号纯净，干扰少。</string>
    <string name="rssi_when_use_title">什么时候参考 RSSI？</string>
    <string name="rssi_when_use_wifi">Wi-Fi 网络：RSSI 是 Wi-Fi 信号的主要指标</string>
    <string name="rssi_when_use_2g">2G/GSM 网络：RSSI 更常用</string>
    <string name="rssi_when_use_proximity">信号快速检查：粗略判断是否靠近基站</string>
    <string name="rssi_assessment_title">当前 RSSI 评估</string>
    <string name="rssi_assessment_good">信号水平在正常范围内。</string>
    <string name="rssi_assessment_fair">有信号但可能存在干扰。</string>
    <string name="rssi_assessment_poor">信号偏低。请确认你处于覆盖良好的区域。</string>

    <!-- Band 科普（新增强化版） -->
    <string name="metric_band_label">Band</string>
    <string name="metric_band_full">工作频段 (Frequency Band)</string>
    <string name="metric_band_desc">频段是无线通信中划分出来的特定频率范围，就像高速公路上的不同车道。</string>
    <string name="metric_band_impact">低频段穿墙能力强但网速慢；高频段（如 n78）网速极快但穿透力弱。</string>
    <string name="metric_band_tip_5g_high">n78/n79 是目前最主流的 5G 高速频段，网速极快但穿透力较弱，室外使用体验最佳。</string>
    <string name="metric_band_tip_5g_mid">n41 是 5G 主力频段，兼顾覆盖与速度，是国内 5G 网络的核心频段。</string>
    <string name="metric_band_tip_lte_mid">B1/B3/B39/B40/B41 是 4G 主力频段，覆盖广、速率均衡，是目前移动网络的中坚力量。</string>
    <string name="metric_band_tip_low">%s 属于低频段，信号覆盖广、穿墙能力强，但网速相对较慢，适合室内和远距离场景。</string>
    <string name="band_explain_title">什么是频段？</string>
    <string name="band_explain_basic">频段是无线通信中划分出来的特定频率范围，就像高速公路上的不同车道。每个频段都有自己独特的特性：频率高低决定了信号的覆盖范围、穿透能力和传输速度。</string>
